PORT=3000

# URL pública deste servidor (sem trailing slash)
PUBLIC_URL=https://mcp.grupopll.com.br

# ── Banco de dados MySQL ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=suasenha
DB_NAME=ai_mcp

# ── JWT (RS256) ─────────────────────────────────────────────────────────────
# Se vazio, o servidor gera um par efêmero na inicialização (tokens são
# invalidados ao reiniciar — ok para dev, não use em produção assim).
#
# Para gerar um par permanente:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out private.pem
#   openssl pkey -in private.pem -pubout -out public.pem
#   JWT_PRIVATE_KEY_B64=$(base64 -w0 private.pem)
#   JWT_PUBLIC_KEY_B64=$(base64 -w0 public.pem)
JWT_PRIVATE_KEY_B64=
JWT_PUBLIC_KEY_B64=

# Duração do access_token em segundos (padrão: 3600 = 1 hora)
JWT_EXPIRES_IN=3600

# ── B2B / pll-erp ───────────────────────────────────────────────────────────
# URL de login do pll-erp (para onde /oauth/authorize redireciona o usuário)
B2B_LOGIN_URL=https://erp.pllb2b.com.br/

# Segredo compartilhado com OAuthCode.php no pll-erp para verificação HMAC-SHA256.
# Deve ser idêntico ao valor de OAUTH_SECRET (ou equivalente) no PHP.
OAUTH_SECRET=sua_chave_secreta_aqui

# ── Grupo PLL API ─────────────────────────────────────────────────────────────
GRUPOPLL_API_URL=https://api.grupopll.com.br
GRUPOPLL_USERNAME=
GRUPOPLL_PASSWORD=
